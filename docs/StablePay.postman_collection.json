{
	"info": {
		"_postman_id": "stablepay-api-collection",
		"name": "StablePay API",
		"description": "StablePay — Cross-border stablecoin remittance on Solana.\n\nUSD → INR corridor via USDC on Solana devnet.\n\nBase URL: http://localhost:8080/api",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "walletId",
			"value": "",
			"type": "string"
		},
		{
			"key": "remittanceId",
			"value": "",
			"type": "string"
		},
		{
			"key": "claimToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "user-001",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Wallets",
			"description": "MPC-backed Solana wallet management",
			"item": [
				{
					"name": "Create Wallet",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('walletId', json.id);",
									"    pm.collectionVariables.set('userId', json.userId);",
									"    pm.test('Wallet created successfully', function () {",
									"        pm.expect(json.id).to.be.a('number');",
									"        pm.expect(json.solanaAddress).to.be.a('string');",
									"        pm.expect(json.availableBalance).to.exist;",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"{{userId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/wallets",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets"]
						},
						"description": "Creates an MPC-backed Solana wallet for the given user.\n\n**Response:** 201 Created\n\n**Errors:**\n- 400 (SP-0003): Validation error\n- 409 (SP-0008): Wallet already exists for this user"
					}
				},
				{
					"name": "Fund Wallet",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.test('Wallet funded successfully', function () {",
									"        pm.expect(json.availableBalance).to.be.a('number');",
									"        pm.expect(json.totalBalance).to.be.a('number');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/fund",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "fund"]
						},
						"description": "Adds demo USDC from the treasury to the wallet.\n\n**Errors:**\n- 404 (SP-0006): Wallet not found\n- 503 (SP-0007): Treasury depleted"
					}
				}
			]
		},
		{
			"name": "FX Rates",
			"description": "Foreign exchange rate lookup",
			"item": [
				{
					"name": "Get FX Rate (USD-INR)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('FX rate returned', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.rate).to.be.a('number');",
									"    pm.expect(json.source).to.be.a('string');",
									"    pm.expect(json.timestamp).to.be.a('string');",
									"    pm.expect(json.expiresAt).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fx/USD-INR",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fx", "USD-INR"]
						},
						"description": "Returns the current exchange rate for USD → INR.\n\n**Errors:**\n- 400 (SP-0009): Unsupported currency corridor"
					}
				}
			]
		},
		{
			"name": "Remittances",
			"description": "Cross-border remittance operations",
			"item": [
				{
					"name": "Create Remittance",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('remittanceId', json.remittanceId);",
									"    if (json.claimTokenId) {",
									"        pm.collectionVariables.set('claimToken', json.claimTokenId);",
									"    }",
									"    pm.test('Remittance created successfully', function () {",
									"        pm.expect(json.remittanceId).to.be.a('string');",
									"        pm.expect(json.status).to.equal('INITIATED');",
									"        pm.expect(json.fxRate).to.be.a('number');",
									"        pm.expect(json.amountInr).to.be.a('number');",
									"        pm.expect(json.claimTokenId).to.be.a('string');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"senderId\": \"{{userId}}\",\n    \"recipientPhone\": \"+919876543210\",\n    \"amountUsdc\": 25.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/remittances",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances"]
						},
						"description": "Initiates a new USD → INR remittance with a locked FX rate.\n\n**Response:** 201 Created\n\n**Errors:**\n- 400 (SP-0003): Validation error\n- 400 (SP-0002): Insufficient balance"
					}
				},
				{
					"name": "Get Remittance",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Remittance retrieved', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.remittanceId).to.equal(pm.collectionVariables.get('remittanceId'));",
									"    pm.expect(json.status).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/remittances/{{remittanceId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances", "{{remittanceId}}"]
						},
						"description": "Retrieves a remittance by its unique identifier.\n\n**Errors:**\n- 404 (SP-0010): Remittance not found"
					}
				},
				{
					"name": "List Remittances",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Remittances listed', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.content).to.be.an('array');",
									"    pm.expect(json.totalElements).to.be.a('number');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/remittances?senderId={{userId}}&page=0&size=20&sort=createdAt,desc",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances"],
							"query": [
								{
									"key": "senderId",
									"value": "{{userId}}"
								},
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "20"
								},
								{
									"key": "sort",
									"value": "createdAt,desc"
								}
							]
						},
						"description": "Returns a paginated list of remittances for a sender.\n\nQuery params `page`, `size`, and `sort` are optional."
					}
				}
			]
		},
		{
			"name": "Claims",
			"description": "Recipient claim flow (SMS link → web page → UPI payout)",
			"item": [
				{
					"name": "Get Claim Details",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Claim details retrieved', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.remittanceId).to.be.a('string');",
									"    pm.expect(json.amountUsdc).to.be.a('number');",
									"    pm.expect(json.amountInr).to.be.a('number');",
									"    pm.expect(json.claimed).to.be.false;",
									"    pm.expect(json.expiresAt).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/claims/{{claimToken}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "claims", "{{claimToken}}"]
						},
						"description": "Retrieves remittance claim details by the claim token sent via SMS.\n\n**Errors:**\n- 404 (SP-0011): Claim token not found\n- 410 (SP-0013): Claim token expired"
					}
				},
				{
					"name": "Submit Claim",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Claim submitted', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.claimed).to.be.true;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"upiId\": \"recipient@upi\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/claims/{{claimToken}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "claims", "{{claimToken}}"]
						},
						"description": "Submits a claim with the recipient's UPI ID to receive INR payout.\n\n**Errors:**\n- 404 (SP-0011): Claim token not found\n- 409 (SP-0012): Claim already submitted\n- 410 (SP-0013): Claim token expired"
					}
				}
			]
		},
		{
			"name": "E2E Flow",
			"description": "Run these requests in order to test the full remittance flow.\nEach step auto-captures variables for the next step.\n\n1. Create Wallet → captures walletId\n2. Fund Wallet (100 USDC)\n3. Check FX Rate (USD-INR)\n4. Create Remittance (25 USDC) → captures remittanceId, claimToken\n5. Poll Remittance Status → verify status progression\n6. Get Claim Details\n7. Submit Claim (UPI)\n8. Verify Final Status\n9. List Remittances",
			"item": [
				{
					"name": "1. Create Wallet",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var uniqueUser = 'e2e-' + Date.now();",
									"pm.collectionVariables.set('userId', uniqueUser);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Wallet created', function () {",
									"    pm.response.to.have.status(201);",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('walletId', json.id);",
									"    pm.expect(json.solanaAddress).to.be.a('string');",
									"    pm.expect(json.availableBalance).to.equal(0);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"{{userId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/wallets",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets"]
						}
					}
				},
				{
					"name": "2. Fund Wallet (100 USDC)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Wallet funded with 100 USDC', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.availableBalance).to.equal(100);",
									"    pm.expect(json.totalBalance).to.equal(100);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 100.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/fund",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "fund"]
						}
					}
				},
				{
					"name": "3. Check FX Rate",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('FX rate available', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.rate).to.be.a('number');",
									"    pm.expect(json.rate).to.be.above(0);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fx/USD-INR",
							"host": ["{{baseUrl}}"],
							"path": ["api", "fx", "USD-INR"]
						}
					}
				},
				{
					"name": "4. Create Remittance (25 USDC)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Remittance created with INITIATED status', function () {",
									"    pm.response.to.have.status(201);",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('remittanceId', json.remittanceId);",
									"    if (json.claimTokenId) {",
									"        pm.collectionVariables.set('claimToken', json.claimTokenId);",
									"    }",
									"    pm.expect(json.status).to.equal('INITIATED');",
									"    pm.expect(json.amountUsdc).to.equal(25);",
									"    pm.expect(json.amountInr).to.be.a('number');",
									"    pm.expect(json.fxRate).to.be.a('number');",
									"    pm.expect(json.claimTokenId).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"senderId\": \"{{userId}}\",\n    \"recipientPhone\": \"+919876543210\",\n    \"amountUsdc\": 25.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/remittances",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances"]
						}
					}
				},
				{
					"name": "5. Poll Remittance Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Remittance status retrieved', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.remittanceId).to.equal(pm.collectionVariables.get('remittanceId'));",
									"    var validStatuses = ['INITIATED', 'ESCROWED', 'CLAIMED', 'DELIVERED'];",
									"    pm.expect(validStatuses).to.include(json.status);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/remittances/{{remittanceId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances", "{{remittanceId}}"]
						},
						"description": "Poll this endpoint to watch status progression:\nINITIATED → ESCROWED → CLAIMED → DELIVERED\n\nWith Temporal running, status should advance to ESCROWED within seconds."
					}
				},
				{
					"name": "6. Get Claim Details",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Claim details show unclaimed remittance', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.remittanceId).to.equal(pm.collectionVariables.get('remittanceId'));",
									"    pm.expect(json.claimed).to.be.false;",
									"    pm.expect(json.amountUsdc).to.equal(25);",
									"    pm.expect(json.expiresAt).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/claims/{{claimToken}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "claims", "{{claimToken}}"]
						},
						"description": "The claimToken is automatically captured from the Create Remittance response."
					}
				},
				{
					"name": "7. Submit Claim (UPI)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Claim submitted successfully', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.claimed).to.be.true;",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"upiId\": \"recipient@upi\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/claims/{{claimToken}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "claims", "{{claimToken}}"]
						},
						"description": "Submits the claim with a UPI ID. After this, the Temporal workflow will release escrow and disburse INR."
					}
				},
				{
					"name": "8. Verify Final Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Remittance reached terminal status', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    var terminalStatuses = ['DELIVERED', 'ESCROWED', 'CLAIMED'];",
									"    pm.expect(terminalStatuses).to.include(json.status);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/remittances/{{remittanceId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances", "{{remittanceId}}"]
						},
						"description": "After claim submission, poll for DELIVERED status.\nWith Temporal running: ESCROWED → CLAIMED → DELIVERED.\nWithout Temporal: status stays as-is (workflow not running)."
					}
				},
				{
					"name": "9. List Remittances",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Sender remittances listed', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.content).to.be.an('array');",
									"    pm.expect(json.content.length).to.be.above(0);",
									"    pm.expect(json.content[0].senderId).to.equal(pm.collectionVariables.get('userId'));",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/remittances?senderId=demo-user&page=0&size=20",
							"host": ["{{baseUrl}}"],
							"path": ["api", "remittances"],
							"query": [
								{
									"key": "senderId",
									"value": "{{userId}}"
								},
								{
									"key": "page",
									"value": "0"
								},
								{
