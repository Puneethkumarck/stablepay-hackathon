		{
			"name": "Remittances",
			"description": "Cross-border remittance operations.\n\nAll endpoints require authentication. The sender identity is derived from the JWT — no `senderId` in request bodies or query params.",
			"item": [
				{
					"name": "Create Remittance",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('remittanceId', json.remittanceId);",
									"    if (json.claimTokenId) {",
									"        pm.collectionVariables.set('claimToken', json.claimTokenId);",
									"    }",
									"    pm.test('Remittance created successfully', function () {",
									"        pm.expect(json.remittanceId).to.be.a('string');",
									"        pm.expect(json.status).to.equal('INITIATED');",
									"        pm.expect(json.fxRate).to.be.a('number');",
									"        pm.expect(json.amountInr).to.be.a('number');",
									"        pm.expect(json.claimTokenId).to.be.a('string');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"recipientPhone\": \"+919876543210\",\n    \"amountUsdc\": 25.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/remittances",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"remittances"
							]
						},
						"description": "Initiates a new USD → INR remittance with a locked FX rate. Sender is identified from the access token.\n\n**Response:** 201 Created\n\n**Errors:**\n- 400 (SP-0003): Validation error\n- 400 (SP-0002): Insufficient balance"
					}
				},
				{
					"name": "Get Remittance",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
