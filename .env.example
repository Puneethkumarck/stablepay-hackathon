# StablePay Docker Compose environment variables
# Copy to .env and fill in values: cp .env.example .env

# Devnet claim authority keypair (base58-encoded secret key)
# Required for escrow claim and refund operations
CLAIM_AUTHORITY_PRIVATE_KEY=

# Solana RPC URL (defaults to devnet if unset)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# USDC mint address (defaults to devnet USDC if unset)
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
